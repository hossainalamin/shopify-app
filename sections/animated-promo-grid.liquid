<!--
  Section: Smart Promo Grid
  File: sections/smart-promo-grid.liquid
  Description: Smart 4-card layout with perfect responsive behavior
  Author: Senior Shopify Developer
  Version: 2.3.1 - Image Quality Optimized
-->

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --card-border-radius: {% if section.settings.rounded_cards %}12px{% else %}0px{% endif %};
    --button-border-radius: {% if section.settings.rounded_buttons %}50px{% else %}4px{% endif %};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --content-alignment: {{ section.settings.content_alignment }};
    --content-bg-opacity: {{ section.settings.content_bg_opacity | divided_by: 100.0 }};
    
    /* Smart Grid Variables */
    --grid-gap: {{ section.settings.grid_gap }}px;
    --main-min-height: {{ section.settings.main_min_height }}px;
    --small-min-height: {{ section.settings.small_min_height }}px;
    --horizontal-min-height: {{ section.settings.horizontal_min_height }}px;
  }

  .smart-promo-grid-{{ section.id }} {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    {% if section.settings.background_color != blank %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
    {% if section.settings.background_gradient != blank %}
      background: {{ section.settings.background_gradient }};
    {% endif %}
    {% if section.settings.background_image %}
      background-image: url({{ section.settings.background_image | image_url: width: 2000 }});
      background-size: cover;
      background-position: center;
    {% endif %}
  }

  .smart-promo-grid__container {
    margin: 0 auto;
  }

  .smart-promo-grid__heading {
    text-align: center;
    margin-bottom: 3rem;
  }

  .smart-promo-grid__heading h2 {
    margin: 0 0 1rem 0;
    font-size: {{ section.settings.heading_size | times: 0.85 }}rem;
  }

  @media screen and (min-width: 750px) {
    .smart-promo-grid__heading h2 {
      font-size: {{ section.settings.heading_size }}rem;
    }
  }

  /* SMART GRID SYSTEM */
  .smart-promo-grid__wrapper {
    display: grid;
    gap: var(--grid-gap);
  }

  /* Default Mobile Layout - All cards stacked */
  .smart-promo-grid__wrapper {
    grid-template-columns: 1fr;
  }

  /* Tablet Layout (750px-989px) */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .smart-promo-grid__wrapper {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto auto;
    }
    
    /* Force specific card positioning */
    .smart-promo-grid__wrapper .promo-card:nth-child(1) {
      grid-column: span 2;
      min-height: var(--main-min-height);
    }
    
    .smart-promo-grid__wrapper .promo-card:nth-child(2) {
      grid-column: 1;
    }
    
    .smart-promo-grid__wrapper .promo-card:nth-child(3) {
      grid-column: 2;
    }
    
    .smart-promo-grid__wrapper .promo-card:nth-child(4) {
      grid-column: span 2;
      min-height: var(--horizontal-min-height);
    }
  }

  /* Desktop Layout (990px+) */
  @media screen and (min-width: 990px) {
    .smart-promo-grid__wrapper {
      grid-template-columns: 2fr 1fr;
      grid-template-rows: 1fr 1fr auto;
      grid-template-areas:
        "main small1"
        "main small2"
        "horizontal horizontal";
      min-height: calc(var(--main-min-height) + var(--horizontal-min-height) + (var(--grid-gap) * 2));
    }
    
    /* Position each card precisely */
    .smart-promo-grid__wrapper .promo-card:nth-child(1) {
      grid-area: main;
      min-height: var(--main-min-height);
    }
    
    .smart-promo-grid__wrapper .promo-card:nth-child(2) {
      grid-area: small1;
      min-height: var(--small-min-height);
    }
    
    .smart-promo-grid__wrapper .promo-card:nth-child(3) {
      grid-area: small2;
      min-height: var(--small-min-height);
    }
    
    .smart-promo-grid__wrapper .promo-card:nth-child(4) {
      grid-area: horizontal;
      min-height: var(--horizontal-min-height);
    }
  }

  /* Card Base Styles */
  .promo-card {
    position: relative;
    border-radius: var(--card-border-radius);
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .promo-card__image-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    /* Maintain aspect ratio based on card position */
  }

  /* Set specific aspect ratios to match uploaded images */
  .smart-promo-grid__wrapper .promo-card:nth-child(1) .promo-card__image-container {
    aspect-ratio: 900/676; /* Main card - 900x676 */
  }

  .smart-promo-grid__wrapper .promo-card:nth-child(2) .promo-card__image-container,
  .smart-promo-grid__wrapper .promo-card:nth-child(3) .promo-card__image-container {
    aspect-ratio: 450/338; /* Small cards - 450x338 */
  }

  .smart-promo-grid__wrapper .promo-card:nth-child(4) .promo-card__image-container {
    aspect-ratio: 900/338; /* Horizontal card - based on your images */
  }

  .promo-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
    /* Ensure image renders sharply */
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
    -ms-interpolation-mode: nearest-neighbor;
  }

  .promo-card:hover .promo-card__image {
    transform: scale(1.05);
  }

  /* Default overlay - bottom to top gradient */
  .promo-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, calc(var(--overlay-opacity) * 0.5)) 0%,
      rgba(0, 0, 0, 0) 100%
    );
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  .promo-card:hover .promo-card__overlay {
    opacity: 0.7;
  }

  .promo-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: clamp(1.5rem, 4vw, 3rem);
    z-index: 2;
    color: white;
    text-align: var(--content-alignment);
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  /* Content background that slides up on hover */
  .promo-card__content::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 0;
    background-color: rgba(0, 0, 0, var(--content-bg-opacity));
    border-radius: 0 0 var(--card-border-radius) var(--card-border-radius);
    z-index: -1;
    transition: height 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .promo-card:hover .promo-card__content::before {
    height: 100%;
  }

  /* Adjust content position on hover for better visibility */
  .promo-card:hover .promo-card__content {
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .promo-card__badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: {{ section.settings.badge_color | default: '#ffffff' }};
    color: {{ section.settings.badge_text_color | default: '#000000' }};
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) 0.1s;
  }

  .promo-card:hover .promo-card__badge {
    opacity: 1;
    transform: translateY(0);
  }

  .promo-card__title {
    margin: 0 0 0.75rem 0;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    line-height: 1.2;
    opacity: 0;
    color:#fff;
    transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) 0.15s;
  }

  .promo-card:hover .promo-card__title {
    opacity: 1;
    transform: translateY(0);
  }

  .promo-card__subtitle {
    margin: 0 0 1.5rem 0;
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    opacity: 0;
    line-height: 1.5;
    max-width: 90%;
    transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) 0.2s;
  }

  .promo-card:hover .promo-card__subtitle {
    opacity: 0.9;
    transform: translateY(0);
  }

  /* Ensure minimum font size of 16px for all text */
  .promo-card__badge,
  .promo-card__title,
  .promo-card__subtitle,
  .promo-card__button {
    font-size: max(16px, 1em);
  }

  /* Button Styles */
  .promo-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2.5rem;
    border-radius: var(--button-border-radius);
    font-weight: 700;
    text-decoration: none;
    border: 2px solid transparent;
    min-width: 150px;
    letter-spacing: 0.05em;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) 0.25s;
  }

  .promo-card:hover .promo-card__button {
    opacity: 1;
    transform: translateY(0);
  }

  .promo-card__button--filled {
    background-color: {{ section.settings.button_color | default: '#ffffff' }};
    color: {{ section.settings.button_text_color | default: '#000000' }};
  }

  .promo-card__button--filled:hover {
    background-color: transparent;
    border-color: {{ section.settings.button_color | default: '#ffffff' }};
    color: {{ section.settings.button_color | default: '#ffffff' }};
  }

  .promo-card__button--outline {
    background-color: transparent;
    border-color: {{ section.settings.button_color | default: '#ffffff' }};
    color: {{ section.settings.button_color | default: '#ffffff' }};
  }

  .promo-card__button--outline:hover {
    background-color: {{ section.settings.button_color | default: '#ffffff' }};
    color: {{ section.settings.button_text_color | default: '#000000' }};
  }

  /* Special Card Types */
  .promo-card:nth-child(1) .promo-card__title {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .promo-card:nth-child(4) .promo-card__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .promo-card:nth-child(4) .promo-card__title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  /* Accessibility */
  .promo-card:focus-visible {
    outline: 3px solid rgba(var(--color-foreground), 0.5);
    outline-offset: 3px;
  }

  /* Touch-friendly states */
  @media (hover: none) {
    .promo-card:active .promo-card__image {
      transform: scale(1.05);
    }
    
    .promo-card:active .promo-card__overlay {
      opacity: 0.7;
    }
    
    .promo-card:active .promo-card__content::before {
      height: 100%;
    }
    
    .promo-card:active .promo-card__content {
      padding-bottom: clamp(2rem, 5vw, 4rem);
    }
    
    .promo-card:active .promo-card__badge,
    .promo-card:active .promo-card__title,
    .promo-card:active .promo-card__subtitle,
    .promo-card:active .promo-card__button {
      opacity: 1;
      transform: translateY(0);
    }
  }
{%- endstyle -%}

{% comment %} {%- javascript -%} {% endcomment %}
 <script>
  class SmartPromoGrid {
    constructor(sectionId) {
      this.section = document.querySelector(`#shopify-section-${sectionId}`);
      this.cards = this.section?.querySelectorAll('.promo-card');
      this.init();
    }

    init() {
      if (!this.cards) return;
      
      // Enhanced keyboard navigation
      this.cards.forEach(card => {
        card.setAttribute('tabindex', '0');
        card.setAttribute('role', 'button');
        
        card.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            window.location.href = card.href;
          }
        });
        
        // Handle focus states for keyboard navigation
        card.addEventListener('focus', () => {
          card.classList.add('promo-card--focused');
        });
        
        card.addEventListener('blur', () => {
          card.classList.remove('promo-card--focused');
        });
      });
      
      // Optional: Add intersection observer for scroll animations
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('promo-card--visible');
            }
          });
        }, { threshold: 0.1 });
        
        this.cards.forEach(card => observer.observe(card));
      }
    }
  }

  // Initialize grid
  document.addEventListener('DOMContentLoaded', () => {
    const sectionId = {{ section.id | json }};
    new SmartPromoGrid(sectionId);
  });

  // Theme Editor support
  if (Shopify.designMode) {
    document.addEventListener('shopify:section:load', (event) => {
      const section = event.target.querySelector('.smart-promo-grid');
      if (section) {
        const sectionId = section.dataset.sectionId;
        new SmartPromoGrid(sectionId);
      }
    });
  }
  </script>

{% comment %} {%- endjavascript -%} {% endcomment %}

<div class="smart-promo-grid smart-promo-grid-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="smart-promo-grid__container page-width">
    {%- if section.settings.heading != blank -%}
      <div class="smart-promo-grid__heading">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="smart-promo-grid__wrapper">
      {%- for block in section.blocks -%}
        {%- assign card_index = forloop.index -%}
        
        {%- liquid
          assign card_url = '#'
          
          case block.settings.link_type
            when 'product'
              if block.settings.product != blank
                assign card_url = block.settings.product.url
              endif
            when 'collection'
              if block.settings.collection != blank
                assign card_url = block.settings.collection.url
              endif
            when 'page'
              if block.settings.page != blank
                assign card_url = block.settings.page.url
              endif
            when 'url'
              if block.settings.custom_url != blank
                assign card_url = block.settings.custom_url
              endif
          endcase

          assign overlay_opacity = block.settings.overlay_opacity | default: 40
          assign overlay_color = block.settings.overlay_color | default: '#000000'
          
          # Set image loading parameters based on card position
          if card_index == 1
            # Main card - use original size 900px
            assign image_width = 900
          elsif card_index == 4
            # Horizontal card - use original width but maintain aspect
            assign image_width = 900
          else
            # Small cards - use original size 450px
            assign image_width = 450
          endif
        -%}

        <a 
          href="{{ card_url }}" 
          class="promo-card"
          {{ block.shopify_attributes }}
          {% if block.settings.title != blank %}
            aria-label="{{ block.settings.title }}"
          {% endif %}
        >
          <div class="promo-card__image-container">
            {%- if block.settings.image != blank -%}
              {%- liquid
                # Use exact sizes based on original image dimensions
                if card_index == 1 or card_index == 4
                  assign sizes = "900px"
                else
                  assign sizes = "450px"
                endif
              -%}
              
              {{ block.settings.image | image_url: width: image_width | image_tag:
                loading: 'lazy',
                class: 'promo-card__image',
                sizes: sizes,
                widths: '450, 900',
                alt: block.settings.title | escape
              }}
            {%- else -%}
              <div class="promo-card__image placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
            
            <!-- Default overlay -->
            <div 
              class="promo-card__overlay" 
              style="background: linear-gradient(to top, {{ overlay_color | color_modify: 'alpha', overlay_opacity | divided_by: 100.0 | times: 0.5 }} 0%, {{ overlay_color | color_modify: 'alpha', 0 }} 100%);"
            ></div>
          </div>
          
          <div class="promo-card__content">
            {%- if block.settings.badge != blank -%}
              <span class="promo-card__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
            
            {%- if block.settings.title != blank -%}
              <h3 class="promo-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            
            {%- if block.settings.subtitle != blank -%}
              <p class="promo-card__subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
            
            {%- if block.settings.button_text != blank -%}
              <span class="promo-card__button promo-card__button--{{ block.settings.button_style }}">
                {{ block.settings.button_text }}
              </span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

